# Environment (copy to `.env.local`; never commit secrets)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Auth redirect base URL (OAuth / magic links). Set on Vercel to your production URL.
# Turn off “Confirm email” for the Email provider in Supabase if you want instant sign-in.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
